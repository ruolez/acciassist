# ── Host ports (chosen from a free-port scan; change if they conflict) ──
PROXY_PORT=8082
BACKEND_PORT=8000
POSTGRES_PORT=5432

# ── PostgreSQL ──
POSTGRES_USER=acciassist
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=acciassist

# ── Backend ──
# "production" makes the backend refuse to boot with dev-default secrets
APP_ENV=development
# Async SQLAlchemy URL (service name "db" resolves inside the compose network)
DATABASE_URL=postgresql+asyncpg://acciassist:change-me-in-prod@db:5432/acciassist
# Secret used to sign admin JWTs — generate a long random value in real envs
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRE_MINUTES=720
# Comma-separated origins allowed by CORS (the proxy origin)
CORS_ORIGINS=http://localhost:8082

# ── First admin (seeded by the seed script) ──
ADMIN_EMAIL=admin@acciassist.com
ADMIN_PASSWORD=changeme123
# Send the admin session cookie only over HTTPS (set true in production w/ SSL)
COOKIE_SECURE=false

# ── Frontend (Vite) ──
# Same-origin in dev: the proxy forwards /api to the backend
VITE_API_BASE=/api
